# PostgreSQL
POSTGRES_DB=english_scheduler
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Backend database connection (the host is the Compose service name)
DATABASE_URL=postgresql+psycopg://postgres:change_me@db:5432/english_scheduler

# Authentication
JWT_SECRET=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Initial development data
BOOTSTRAP_ORG_NAME=Mi Escuela
BOOTSTRAP_ORG_SLUG=mi-escuela
BOOTSTRAP_BRANCH_NAME=Matriz
BOOTSTRAP_BRANCH_CODE=MATRIZ
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace_with_a_secure_password

# Browser origins allowed to call the API
CORS_ORIGINS=http://localhost:5173
