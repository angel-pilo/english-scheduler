JWT_SECRET=CHANGE_ME_SUPER_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Bootstrap (primer admin)
BOOTSTRAP_ORG_NAME=Mi Escuela
BOOTSTRAP_BRANCH_NAME=Matriz
BOOTSTRAP_ADMIN_EMAIL=admin@escuela.com
